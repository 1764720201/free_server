// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/**
 * 用户表
 */
model User {
  id        String        @id @default(uuid())
  email     String        @unique
  password  String
  name      String?
  phone     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

/**
 * 聊天消息表
 */
model ChatMessage {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
}

/**
 * 基金目录表
 */
model FundCatalog {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  type        String?
  pinyinShort String?
  pinyinFull  String?
  source      String   @default("east-money")
  syncedAt    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([pinyinShort])
  @@index([pinyinFull])
}

/**
 * 基金目录同步日志
 */
model FundCatalogSyncRun {
  id            String    @id @default(uuid())
  source        String    @default("east-money")
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String // "running" | "success" | "failed"
  totalFetched  Int?
  upsertedCount Int?
  updatedCount  Int?
  insertedCount Int?
  errorMessage  String?

  runDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([runDate])
}

/**
 * 基金每日净值表
 */
model FundDailyPrice {
  id        String   @id @default(uuid())
  code      String
  date      DateTime
  nav       Decimal
  accNav    Decimal?
  source    String   @default("east-money-fundgz")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, date])
  @@index([code, date])
}

/**
 * 股票/ETF 目录表
 */
model SecurityCatalog {
  id String @id @default(uuid())

  secid     String
  tradeDate DateTime
  open      Decimal
  high      Decimal
  low       Decimal
  close     Decimal

  vol    Decimal?
  amount Decimal?

  pctChg   Decimal?
  chg      Decimal?
  turnover Decimal?

  source String @default("east-money-push2his")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([secid, tradeDate])
  @@index([secid, tradeDate])
}

/**
 * 股票/ETF 每日净值表
 */
model SecurityDailyPrice {
  id        String   @id @default(uuid())
  secid     String
  tradeDate DateTime

  open  Decimal
  high  Decimal
  low   Decimal
  close Decimal

  vol    Decimal?
  amount Decimal?

  pctChg   Decimal?
  chg      Decimal?
  turnover Decimal?
  source   String   @default("east-money-push2his")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([secid, tradeDate])
  @@index([secid, tradeDate])
}
